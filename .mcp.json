{
  "mcpServers": {
    "event-horizon": {
      "type": "http",
      "url": "http://127.0.0.1:3067/mcp",
      "alwaysLoad": true
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "basic-memory": {
      "command": "uvx",
      "args": [
        "basic-memory",
        "mcp"
      ]
    },
    "serena": {
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd",
        "--open-web-dashboard",
        "False",
        "--enable-gui-log-window",
        "False"
      ]
    }
  }
}
