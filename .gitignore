node_modules/
dist/
build/
.env
.DS_Store
*.log
.npm-cache/
.claude/
.clauderc
releases/

# Generated by npm run build — injected into the Windows SEA binary at package time
engine/sea-config.json

# TypeScript build output (emitted in-place by tsc)
engine/src/**/*.js
engine/src/**/*.js.map
engine/src/**/*.d.ts
engine/src/**/*.d.ts.map
engine/vitest.config.js
engine/vitest.config.js.map
engine/vitest.config.d.ts
engine/vitest.config.d.ts.map

# flux-data orphan mode
.flux/*.md
.flux/config.json
.flux/assets/

# orphan worktree directory (managed by git worktree, not committed to master)
.flux-store/

# FLUX-763 Phase 4: onboarding Studio draft store. Routine Studio Save writes these
# gitignored drafts (never the committed onboardingFlow.json/onboardingFeatures.json),
# so merely opening + saving in the Studio leaves `git status` clean and never blocks
# `git pull`. Only an explicit Publish writes the committed configs. The wizard never
# imports *.draft.json, so drafts never enter the prod bundle. *.tmp covers the atomic
# temp-sibling writes (draft AND committed) so a crashed write can't leak a stray file.
portal/src/config/*.draft.json
portal/src/config/*.tmp

# Throwaway file-locking debug scratch at the repo root — keep `git add -A` from
# sweeping it back in if the experiment is ever re-run (FLUX-508).
/keep-open.js
/lock-file.js
/test-unlink.js
