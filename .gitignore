node_modules
node_modules/
dist/
build/
# …but keep the Electron desktop app icons (committed assets, generated by
# electron/scripts/gen-icons.mjs) despite the global build/ ignore (FLUX-793).
!electron/build/
!electron/build/**
.env
.DS_Store
*.log
.npm-cache/
.claude/
.clauderc
releases/

# Internal-only — agent scaffolding + maintainer notes, never shipped to the public repo (FLUX-870)
.agents/
.dev-notes/

# FLUX-958: dogfooded agent-skill INSTALL OUTPUTS. bootstrap.ts re-installs these on every
# engine boot from the committed sources (.docs/skills/*.md and
# .flux/skills/event-horizon-copilot-instructions.md), always overwriting — so the generated
# copies are pure build output. Tracking them only ships duplicates that drift from source, and
# publish-public mirrors the dev tree 1:1, so they'd leak to the public repo too. EH regenerates
# them locally on activation. KEPT on purpose (NOT generated): .github/workflows/ (CI),
# .gemini/settings.json (hand-authored). .claude/ + .clauderc are already ignored above.
.github/copilot-instructions.md
.github/skills/event-horizon/
.gemini/instructions.md
.gemini/skills/event-horizon.md
engine/.event-horizon/
engine/.gemini/

# Generated by npm run build — injected into the Windows SEA binary at package time
engine/sea-config.json

# TypeScript build output (emitted in-place by tsc)
engine/src/**/*.js
engine/src/**/*.js.map
engine/src/**/*.d.ts
engine/src/**/*.d.ts.map
engine/vitest.config.js
engine/vitest.config.js.map
engine/vitest.config.d.ts
engine/vitest.config.d.ts.map

# flux-data orphan mode
.flux/*.md
.flux/config.json
.flux/assets/
# FLUX-833: durable open-prompts index — process-local in-flight HITL state, never committed.
.flux/open-prompts.json
.flux/open-prompts.json.tmp
# FLUX-894: persisted session→ticket binding secret — local-only credential, never committed/synced.
.flux/session-binding-secret
.flux/session-binding-secret.tmp
# FLUX-1060: persisted active-session stubs — process-local runtime state for restart-safe worktree
# reclaim, never committed/synced.
.flux/sessions/

# orphan worktree directory (managed by git worktree, not committed to master)
.flux-store/

# FLUX-763 Phase 4: onboarding Studio draft store. Routine Studio Save writes these
# gitignored drafts (never the committed onboardingFlow.json/onboardingFeatures.json),
# so merely opening + saving in the Studio leaves `git status` clean and never blocks
# `git pull`. Only an explicit Publish writes the committed configs. The wizard never
# imports *.draft.json, so drafts never enter the prod bundle. *.tmp covers the atomic
# temp-sibling writes (draft AND committed) so a crashed write can't leak a stray file.
portal/src/config/*.draft.json
portal/src/config/*.tmp

# Throwaway file-locking debug scratch at the repo root — keep `git add -A` from
# sweeping it back in if the experiment is ever re-run (FLUX-508).
/keep-open.js
/lock-file.js
/test-unlink.js
