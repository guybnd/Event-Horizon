{
  "mcpServers": {
    "event-horizon": {
      "httpUrl": "http://127.0.0.1:3067/mcp",
      "headers": {
        "x-eh-conversation-id": "${EH_CONVERSATION_ID}",
        "x-eh-conversation-token": "${EH_CONVERSATION_TOKEN}"
      }
    },
    "serena": {
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd",
        "--open-web-dashboard",
        "False",
        "--enable-gui-log-window",
        "False"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "basic-memory": {
      "command": "uvx",
      "args": [
        "basic-memory",
        "mcp"
      ],
      "env": {
        "BASIC_MEMORY_HOME": "C:\\GitHub\\EventHorizon\\.flux-store/memory"
      }
    }
  }
}
