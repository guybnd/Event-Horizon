{
  "name": "engine",
  "version": "1.7.0",
  "description": "Event Horizon engine — Express + TypeScript API, MCP server, and agent orchestration for the local-first ticket board.",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "dev": "tsx src/dev-watcher.ts -- --workspace ..",
    "dev:no-watch": "tsx src/index.ts --workspace ..",
    "build": "node scripts/build.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "init": "tsx src/init.ts",
    "init-group": "tsx src/init-group.ts",
    "install-skill": "tsx src/skill-installer.ts",
    "flux:release": "tsx src/release.ts",
    "flux:reset-remote": "tsx src/reset-remote.ts",
    "patch-ticket": "tsx src/patch-ticket.ts",
    "package": "npm run build && node scripts/package-release.js",
    "package:win": "npm run build && node scripts/package-release.js --platform win",
    "package:mac": "npm run build && node scripts/package-release.js --platform mac",
    "test": "vitest run"
  },
  "keywords": [
    "event-horizon",
    "ai-agents",
    "agent-orchestration",
    "mcp",
    "ticket-board",
    "local-first"
  ],
  "author": "guybnd",
  "homepage": "https://github.com/guybnd/Event-Horizon#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guybnd/Event-Horizon.git",
    "directory": "engine"
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/ws": "^8.18.1",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "node-pty": "^1.1.0",
    "systray": "^1.0.5",
    "ws": "^8.21.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "pkg": {
    "assets": [
      "dist/portal/dist/**/*",
      "dist/.docs/skills/**/*",
      "dist/.docs/event-horizon/**/*",
      "dist/.flux/skills/**/*",
      "dist/traybin/**/*"
    ],
    "targets": [
      "node22-macos-arm64"
    ],
    "outputPath": "dist"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.27.7",
    "postject": "1.0.0-alpha.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
